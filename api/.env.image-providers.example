# ===========================================
# IMAGE PROVIDER CONFIGURATION
# ===========================================
# Choose which image provider to use: 'imgix' or 'imagekit'
# Default: imgix (for backward compatibility)
IMAGE_PROVIDER=imgix

# ===========================================
# IMGIX CONFIGURATION (if IMAGE_PROVIDER=imgix)
# ===========================================
NEXT_PUBLIC_IMGIX_URL=your-source.imgix.net
NEXT_PUBLIC_IMGIX_SECURE_URL_TOKEN=your-secure-token

# ===========================================
# IMAGEKIT CONFIGURATION (if IMAGE_PROVIDER=imagekit)
# ===========================================
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id
IMAGEKIT_PUBLIC_KEY=your_public_key
IMAGEKIT_PRIVATE_KEY=your_private_key

# For frontend apps (admin/client)
NEXT_PUBLIC_IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id
